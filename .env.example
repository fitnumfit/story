# Vercel Blob — required for saving responses & interactions
# Get these from: Vercel Dashboard → Storage → your Blob store → .env.local tab
# Or: Project → Settings → Environment Variables

BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx
BLOB_STORE_ID=store_xxxxxxxx

# After adding on Vercel: Deployments → Redeploy (env vars only apply after redeploy)
# Local dev: copy to .env.local, then run: npx vercel dev
